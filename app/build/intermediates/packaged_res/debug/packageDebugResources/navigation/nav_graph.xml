<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.spiderybook.ui.home.HomeFragment"
        android:label="Home" />
        
    <fragment
        android:id="@+id/nav_search"
        android:name="com.spiderybook.ui.search.SearchFragment"
        android:label="Search" />

    <fragment
        android:id="@+id/nav_result"
        android:name="com.spiderybook.ui.result.ResultFragment"
        android:label="Result">
        <argument
            android:name="url"
            app:argType="string" />
            android:name="apiName"
            app:argType="string" />
        <action
            android:id="@+id/action_nav_result_self"
            app:destination="@id/nav_result" />
    </fragment>
    
    <fragment
        android:id="@+id/nav_downloads"
        android:name="com.spiderybook.ui.downloads.DownloadsFragment"
        android:label="Downloads" />

    <fragment
        android:id="@+id/nav_favorites"
        android:name="com.spiderybook.ui.favorites.FavoritesFragment"
        android:label="Favorites" />

    <fragment
        android:id="@+id/nav_history"
        android:name="com.spiderybook.ui.history.HistoryFragment"
        android:label="History" />

    <fragment
        android:id="@+id/nav_settings"
        android:name="com.spiderybook.ui.settings.SettingsFragment"
        android:label="Settings" />

</navigation>
