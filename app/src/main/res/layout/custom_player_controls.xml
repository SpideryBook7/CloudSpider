<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4D000000"> <!-- Dark translucent overlay when controls are visible -->

    <!-- EXO PLAYER NATIVE QUARANTINE HOOKS -->
    <!-- Captures Media3's auto-injections to paralyze layout rendering and prevent SVG overwrites -->
    <ImageView android:id="@id/exo_rew" android:layout_width="0dp" android:layout_height="0dp" android:alpha="0" />
    <ImageView android:id="@id/exo_ffwd" android:layout_width="0dp" android:layout_height="0dp" android:alpha="0" />
    <ImageView android:id="@id/exo_play" android:layout_width="0dp" android:layout_height="0dp" android:alpha="0" />
    <ImageView android:id="@id/exo_pause" android:layout_width="0dp" android:layout_height="0dp" android:alpha="0" />

    <!-- TOP BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="24dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            app:srcCompat="@drawable/ic_arrow_back_custom"
            app:tint="@color/white"
            android:padding="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Title & Subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintEnd_toStartOf="@id/btn_cast_control"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tv_player_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Cyber Odyssey" />

            <TextView
                android:id="@+id/tv_player_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Episode 12: Neon Ghosts" />
        </LinearLayout>

        <!-- CAST, SOURCES, SETTINGS -->
        <ImageView
            android:id="@+id/btn_cast_control"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_cast_custom"
            android:padding="6dp"
            app:tint="@color/white"
            app:layout_constraintEnd_toStartOf="@id/btn_sources_control"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="16dp"/>

        <ImageView
            android:id="@+id/btn_sources_control"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_subtitles_custom"
            android:padding="6dp"
            android:visibility="gone"
            app:tint="@color/white"
            app:layout_constraintEnd_toStartOf="@id/btn_quality_settings"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="16dp"/>

        <ImageView
            android:id="@+id/btn_quality_settings"
            android:layout_width="32dp"
            android:layout_height="32dp"
            app:srcCompat="@drawable/ic_settings_custom"
            android:padding="6dp"
            app:tint="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CENTER CONTROLS -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btn_rewind_custom"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_dark_glass"
            app:srcCompat="@drawable/ic_replay_10"
            app:tint="@color/white"
            android:padding="14dp"
            android:scaleType="centerInside"
            android:contentDescription="Rewind 10s" />

        <ImageView
            android:id="@+id/btn_play_custom"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:background="@drawable/bg_circle_purple"
            app:srcCompat="@drawable/ic_play_arrow_custom"
            app:tint="@color/white"
            android:padding="16dp"
            android:scaleType="centerInside"
            android:visibility="visible" />

        <ImageView
            android:id="@+id/btn_pause_custom"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:background="@drawable/bg_circle_dark_glass"
            app:srcCompat="@drawable/ic_pause_custom"
            app:tint="@color/white"
            android:padding="16dp"
            android:scaleType="centerInside"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/btn_forward_custom"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_dark_glass"
            app:srcCompat="@drawable/ic_forward_10"
            app:tint="@color/white"
            android:padding="14dp"
            android:scaleType="centerInside"
            android:contentDescription="Forward 10s" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_skip_intro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Saltar Intro ⏭"
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#4D000000"
        app:cornerRadius="8dp"
        android:visibility="gone"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="1dp"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_top_bar"/>

    <!-- SECURE FLOATING LOCK (Vertical Center Left) -->
    <LinearLayout
        android:id="@+id/layout_lock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/btn_lock"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_dark_glass"
            app:srcCompat="@drawable/ic_lock_custom"
            app:tint="@color/text_secondary"
            android:padding="10dp"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/tv_lock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOCK"
            android:textSize="8sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <!-- BOTTOM BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp"
        android:paddingHorizontal="48dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next_episode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Siguiente Ep. ⏭"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#4D000000"
            app:cornerRadius="8dp"
            android:visibility="gone"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="1dp"
            android:elevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/exo_progress"/>

        <!-- TIMEBAR -->
        <androidx.media3.ui.DefaultTimeBar
            android:id="@id/exo_progress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:played_color="@color/brand_accent"
            app:unplayed_color="#4DFFFFFF"
            app:scrubber_color="@color/white"
            app:bar_height="2dp"
            app:scrubber_dragged_size="16dp"
            app:scrubber_enabled_size="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/layout_bottom_metrics"
            android:layout_marginBottom="12dp"/>

        <!-- BOTTOM METRICS & TOOLS -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_bottom_metrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- TIMERS -->
            <TextView
                android:id="@id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/tv_divider"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / "
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                app:layout_constraintStart_toEndOf="@id/exo_position"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                app:layout_constraintStart_toEndOf="@id/tv_divider"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- TOOLS (Right aligned) -->
            <ImageView
                android:id="@+id/btn_fullscreen"
                android:layout_width="28dp"
                android:layout_height="28dp"
                app:srcCompat="@drawable/ic_fullscreen_custom"
                android:padding="2dp"
                app:tint="@color/text_secondary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageView
                android:id="@+id/btn_aspect_ratio"
                android:layout_width="28dp"
                android:layout_height="28dp"
                app:srcCompat="@drawable/ic_aspect_ratio_custom"
                android:padding="2dp"
                app:tint="@color/text_secondary"
                app:layout_constraintEnd_toStartOf="@id/btn_fullscreen"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" 
                android:layout_marginEnd="16dp"/>

            <TextView
                android:id="@+id/btn_episodes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EPISODES"
                android:textSize="9sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:drawablePadding="6dp"
                android:paddingHorizontal="16dp"
                app:drawableStartCompat="@drawable/ic_episodes_custom"
                app:drawableTint="@color/white"
                app:layout_constraintEnd_toStartOf="@id/btn_aspect_ratio"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/btn_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.0X"
                android:textSize="9sp"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                app:drawableStartCompat="@drawable/ic_speed_custom"
                app:drawableTint="@color/text_secondary"
                android:drawablePadding="4dp"
                app:layout_constraintEnd_toStartOf="@id/btn_episodes"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
