<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_gravity="bottom">

    <!-- Center Play/Pause -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal">

        <ImageButton android:id="@id/exo_rew"
            style="@style/ExoMediaButton.Rewind"/>

        <!-- Overlap Play and Pause to create a single toggle effect -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageButton android:id="@+id/btn_play_custom"
                style="@style/ExoMediaButton.Play"
                android:layout_gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="visible"/>
            <ImageButton android:id="@+id/btn_pause_custom"
                style="@style/ExoMediaButton.Pause"
                android:layout_gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone"/>
        </FrameLayout>

        <ImageButton android:id="@id/exo_ffwd"
            style="@style/ExoMediaButton.FastForward"/>
    </LinearLayout>

    <!-- Bottom Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#80000000"
        android:padding="8dp">

        <!-- Scrubber -->
        <androidx.media3.ui.DefaultTimeBar
            android:id="@id/exo_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Bottom Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView android:id="@id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:includeFontPadding="false"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"/>

            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/"
                android:textColor="#CBCBCB"/>

            <TextView android:id="@id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#CBCBCB"
                android:includeFontPadding="false"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"/>

            <View android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- SOURCES BUTTON -->
            <ImageButton
                android:id="@+id/btn_sources_control"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Sources"
                android:padding="12dp"
                android:visibility="gone"
                app:tint="@android:color/white"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

            <!-- CAST BUTTON -->
            <ImageButton
                android:id="@+id/btn_cast_control"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_share"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Cast to TV"
                android:padding="12dp"
                app:tint="@android:color/white"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

            <!-- ASPECT RATIO BUTTON -->
            <ImageButton
                android:id="@+id/btn_aspect_ratio"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_crop"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Aspect Ratio"
                android:padding="12dp"
                app:tint="@android:color/white"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

            <!-- FULLSCREEN BUTTON (Change icon to ROTATE to distinguish) -->
            <ImageButton
                android:id="@+id/btn_fullscreen"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_rotate"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Rotate Screen"
                android:padding="12dp"
                app:tint="@android:color/white"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

            <!-- QUALITY/SETTINGS BUTTON (Gear Icon) -->
            <ImageButton
                android:id="@+id/btn_quality_settings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_preferences"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Quality Settings"
                android:padding="12dp"
                app:tint="@android:color/white"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_skip_intro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="90dp"
        android:layout_marginEnd="24dp"
        android:text="Saltar Intro ⏭"
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#4D000000"
        app:cornerRadius="8dp"
        android:visibility="gone"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="1dp"
        android:elevation="4dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <!-- FLOATING NEXT EPISODE BUTTON -->
    <!-- Positioned at the bottom right, slightly above the control bar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_next_episode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="140dp"
        android:layout_marginEnd="24dp"
        android:text="Siguiente Ep. ⏭"
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#4D000000"
        app:cornerRadius="8dp"
        android:visibility="gone"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="1dp"
        android:elevation="4dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</FrameLayout>
